# klab "bpf-min" kernel config fragment.
#
# Layered over `make ARCH=<arch> defconfig` (see internal/kernel MakeBuilder).
# Enables eBPF/BTF/XDP + cgroup-BPF for eBPF work, and 9p-over-virtio so the
# kernel can boot with a 9p-exported rootfs (klab's direct `-kernel` boot).

# eBPF core, JIT, tracing, XDP sockets, cgroup + tc classifiers.
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_CGROUP_BPF=y
CONFIG_XDP_SOCKETS=y
CONFIG_NET_CLS_BPF=y

# BTF type info (bpftool, CO-RE). Requires full — not reduced — DWARF plus a
# recent pahole; arm64/x86 defconfig sets DEBUG_INFO_REDUCED, which blocks BTF.
# CONFIG_DEBUG_INFO_REDUCED is not set
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_DEBUG_INFO_BTF=y

# 9p-over-virtio root filesystem for direct `-kernel` boot.
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
